!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# ---- Python ----
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# venv
.venv/
venv/
env/
.env

# ---- Data / Results (keep folders, ignore contents) ----
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

results/runs/*
results/figures/*
results/logs/*
!results/runs/.gitkeep
!results/figures/.gitkeep
!results/logs/.gitkeep

