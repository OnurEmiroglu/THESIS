# ---- OS ----
.DS_Store
Thumbs.db

# ---- VS Code (track only what we need) ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# ---- Python ----
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# venv
.venv/
venv/
env/
.env

# ---- Data / Results (keep folders, ignore contents) ----
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

results/runs/*
results/figures/*
results/logs/*
!results/runs/.gitkeep
!results/figures/.gitkeep
!results/logs/.gitkeep

# ---- Thesis build outputs ----
manuscript/build/
unpacked_thesis/

# ---- Linter ----
.ruff_cache/

# ---- Node ----
node_modules/

# ---- Logs ----
*.log


results/runs/*
!results/runs/.gitkeep

# ---- Word/Office temp files ----
~$*
~WRL*.tmp

# ---- Claude Code harness runtime lockfiles ----
.claude/*.lock

# HFMM_REALDATA raw + processed datasets (large binaries, downloaded artifacts)
HFMM_REALDATA/data/raw/*
HFMM_REALDATA/data/processed/*
!HFMM_REALDATA/data/raw/.gitkeep
!HFMM_REALDATA/data/processed/.gitkeep
!HFMM_REALDATA/data/raw/_manifest.json
